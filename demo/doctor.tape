# Autopus-ADK Doctor Demo — Health Check
# Usage: cd demo && vhs doctor.tape

Output doctor.gif

Require auto

Set Shell "zsh"
Set FontSize 18
Set Width 1200
Set Height 600
Set Padding 20
Set Theme "Dracula"
Set TypingSpeed 50ms
Set WindowBar Colorful
Set WindowBarSize 40
Set CursorBlink true

Type "auto doctor"
Enter
Sleep 5s
